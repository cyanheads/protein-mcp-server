{
  "name": "protein-mcp-server",
  "version": "0.4.0",
  "description": "Federated protein structure & annotation across experimental (PDB) and predicted (AlphaFold) models.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/protein-mcp-server#readme",
  "repository": "https://github.com/cyanheads/protein-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "protein-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/protein-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
